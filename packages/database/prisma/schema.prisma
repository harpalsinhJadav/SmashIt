// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  OWNER
  PLAYER
}

enum CourtType {
  BADMINTON
  TENNIS
  SQUASH
  BASKETBALL
  FOOTBALL
  CRICKET
}

enum Status {
  ACTIVE
  UNDER_REVIEW
  MAINTENANCE
  INACTIVE
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String?
  password     String
  phoneNumber  String?
  avatarUrl    String?
  role         Role     @default(PLAYER)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Relationships
  bookings     Booking[]
  ownerProfile Owner?
  reviews      Review[]
}

model Owner {
  id        String   @id @default(cuid())
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id])
  courts    Court[]
}

model Court {
  id          String   @id @default(cuid())
  name        String
  description String?
  location    String
  address     String?
  latitude    Float?
  longitude   Float?
  type        CourtType @default(BADMINTON)
  status      Status    @default(UNDER_REVIEW)
  facilities  String[]  // ["Parking", "WiFi", "Water"]
  pricePerHour Float
  mainImage   String?
  
  ownerId     String
  owner       Owner    @relation(fields: [ownerId], references: [id])
  
  slots       Slot[]
  bookings    Booking[]
  reviews     Review[]
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Slot {
  id          String   @id @default(cuid())
  courtId     String
  court       Court    @relation(fields: [courtId], references: [id])
  startTime   String   // e.g., "06:00"
  endTime     String   // e.g., "07:00"
  price       Float?   // Override court price if specific slots cost more
  isAvailable Boolean  @default(true)

  @@unique([courtId, startTime, endTime])
}

model Booking {
  id          String        @id @default(cuid())
  courtId     String
  court       Court         @relation(fields: [courtId], references: [id])
  userId      String
  user        User          @relation(fields: [userId], references: [id])
  
  bookingDate DateTime
  startTime   String        // Reference to Slot.startTime
  endTime     String        // Reference to Slot.endTime
  totalAmount Float
  
  status      BookingStatus @default(PENDING)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
}

model Review {
  id        String   @id @default(cuid())
  rating    Int      @default(5)
  comment   String?
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  courtId   String
  court     Court    @relation(fields: [courtId], references: [id])
  createdAt DateTime @default(now())
}
