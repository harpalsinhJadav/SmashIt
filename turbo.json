{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build", "generate"],
      "outputs": [".next/**", "dist/**", "build/**"]
    },
    "generate": {
      "dependsOn": ["^generate"],
      "outputs": ["generated/**"]
    },
    "lint": {
      "dependsOn": ["^lint", "generate"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "test": {
      "dependsOn": ["build"],
      "outputs": ["coverage/**"]
    }
  }
}
