{
  "name": "smashit-monorepo",
  "private": true,
  "packageManager": "npm@10.9.3",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "generate": "turbo run generate",
    "dev": "turbo run dev",
    "dev:all": "turbo run dev",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "api:dev": "npm run dev -w apps/api",
    "admin:dev": "npm run dev -w apps/admin",
    "mobile:start": "npm run start -w apps/mobile",
    "mobile:android": "npm run android -w apps/mobile",
    "mobile:ios": "npm run ios -w apps/mobile",
    "test": "turbo run test",
    "prepare": "husky || true"
  },
  "devDependencies": {
    "eslint": "^10.0.3",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "eslint-plugin-unused-imports": "^4.4.1",
    "husky": "^9.1.7",
    "lint-staged": "^16.3.3",
    "prettier": "2.8.8",
    "turbo": "^2.1.2"
  },
  "engines": {
    "node": ">= 22.11.0"
  }
}
