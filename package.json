{
  "name": "smashit-monorepo",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "mobile:start": "npm run start -w apps/mobile",
    "mobile:android": "npm run android -w apps/mobile",
    "mobile:ios": "npm run ios -w apps/mobile",
    "test": "turbo run test"
  },
  "devDependencies": {
    "turbo": "^2.1.2",
    "prettier": "2.8.8"
  },
  "engines": {
    "node": ">= 22.11.0"
  }
}
